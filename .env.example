# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
# Tidszon för morgonjobbet (Anna sitter i Sverige)
TZ=Europe/Stockholm

# ─── Admin-inloggning ────────────────────────────────────────────────────────
# Användarnamn för dashboarden
ADMIN_USERNAME=anna
# Lösenord. Sätt ett riktigt vid driftsättning. Hashas automatiskt vid start.
ADMIN_PASSWORD=byt-mig-direkt
# Slumpmässig sträng som signerar inloggnings-cookien (generera en lång random)
SESSION_SECRET=byt-till-en-lang-slumpmassig-strang

# ─── Databas ─────────────────────────────────────────────────────────────────
# Sökväg till SQLite-filen. På Railway: peka mot en monterad volym, t.ex. /data/app.sqlite
DATABASE_PATH=./data/app.sqlite

# ─── BookVisit ───────────────────────────────────────────────────────────────
BOOKVISIT_BASE_URL=https://restapi.bookvisit.com
BOOKVISIT_API_KEY=din-bookvisit-api-nyckel
BOOKVISIT_CHANNEL_ID=ditt-bookvisit-channel-id

# ─── SMS via 46elks ──────────────────────────────────────────────────────────
# https://46elks.se – API-användare/lösenord finns i deras dashboard
ELKS_API_USERNAME=
ELKS_API_PASSWORD=
# Avsändare som visas i SMS:et (max 11 tecken, bokstäver). T.ex. "Honosjobod"
SMS_SENDER=Honosjobod

# ─── E-post (fallback när telefonnummer saknas) ──────────────────────────────
# SMTP-uppgifter. T.ex. egen e-postleverantör eller Brevo/Postmark/Resend SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Hönö Sjöbodar <anna@pegonia.se>

# ─── Säkerhetsspärr / test ───────────────────────────────────────────────────
# true = inget riktigt skickas, allt loggas som "dry-run" (perfekt för test)
DRY_RUN=true
# Om satt: ALLA meddelanden går istället till detta nummer/mail (canary-läge)
CANARY_PHONE=
CANARY_EMAIL=

# ─── Morgonjobb ──────────────────────────────────────────────────────────────
# När det automatiska utskicket körs (cron-uttryck, i TZ ovan). Default 07:00.
CRON_SCHEDULE=0 7 * * *
# true = skicka automatiskt på morgonen. false = förbered bara, Anna trycker skicka.
AUTO_SEND=false
