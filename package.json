{
  "name": "hono-sjobodar",
  "version": "1.0.0",
  "private": true,
  "description": "Automatisk utskick av dörrkoder via SMS/e-post till dagens incheckande gäster på Hönö Sjöbodar (BookVisit).",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "start": "tsx src/index.tsx",
    "seed": "tsx scripts/seed.ts",
    "send:today": "tsx scripts/run-job.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
